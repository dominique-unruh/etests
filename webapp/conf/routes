# Routes
# This file defines all application routes (Higher priority routes first)
# https://www.playframework.com/documentation/latest/ScalaRouting
# ~~~~

GET     /                                    controllers.AssessmentController.defaultRedirect()
GET     /preview/                            controllers.AssessmentController.allExams()
GET     /preview/:exam/                      controllers.AssessmentController.exam(exam)
GET     /preview/:exam/:assessment/          controllers.AssessmentController.assessment(exam, assessment)
GET     /preview/:exam/:assessment/:file     controllers.AssessmentController.assessmentFile(exam, assessment, file)
POST    /answers/:exam/:assessment/:kind    controllers.AssessmentController.loadAnswers(exam, assessment, kind)
#GET     /reference/:exam/:assessment         controllers.AssessmentController.loadReference(exam, assessment)
POST    /feedback/:exam/:assessment controllers.AssessmentController.getFeedback(exam, assessment)
GET     /routes.js                           controllers.MiscController.javascriptRoutes
GET     /randomstudent/:exam                      controllers.AssessmentController.randomStudent(exam)
GET     /dynexitelink/:exam/:regno                      controllers.AssessmentController.dynexiteLink(exam, regno)
GET     /dynexitepdf/:exam/:regno.pdf                      controllers.AssessmentController.dynexitePdf(exam, regno)
GET     /dynexiteanswers/:exam/:assessment/:regno                      controllers.AssessmentController.dynexiteAnswers(exam, assessment, regno)

GET     /assets/*file               controllers.Assets.versioned(path="/public", file: Asset)
GET     /favicon.ico   controllers.Assets.at(path="/public/images", file="favicon.ico")
GET     /test controllers.AssessmentController.test()
